# TikTok crawler configuration
# Copy to .env and fill in values before running

# Required TikTok session token (from browser cookies)
ms_token="your_ms_token_here"

# Run this many users per run (avoid brute force) - set to 3 for testing
MAX_USERS_PER_RUN=3

# Filter to only Vietnam-based creators (1 for true, 0 for false)
VIETNAM_ONLY=1

# Run browser in headless mode (1 for headless/no UI, 0 for show browser)
HEADLESS=1

# Browser locale to appear from Vietnam (helps TikTok geo-detect)
# Set to vi-VN for Vietnamese or vi for generic Vietnamese
BROWSER_LOCALE=vi-VN

# Browser timezone - set to Asia/Ho_Chi_Minh for Vietnam timezone
BROWSER_TIMEZONE=Asia/Ho_Chi_Minh

# Optional explicit user agent; helps avoid default automation bot fingerprint
TIKTOK_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"

# Process saved users instead of searching hashtags (1 to process saved, 0 to collect)
PROCESS_SAVED_USERS=0
