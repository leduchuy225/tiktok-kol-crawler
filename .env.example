# TikTok crawler configuration
# Copy to .env and fill in values before running

# Required TikTok session token (from browser cookies)
ms_token=""

# Run this many users per run (avoid brute force) - set to 3 for testing
MAX_USERS_PER_RUN=3

#PROXY_URL=1

# Run browser in headless mode (1 for headless/no UI, 0 for show browser)
HEADLESS=1

# Browser locale to appear from Vietnam (helps TikTok geo-detect)
# Set to vi-VN for Vietnamese or vi for generic Vietnamese
BROWSER_LOCALE=vi-VN

# # Browser timezone - set to Asia/Ho_Chi_Minh for Vietnam timezone
BROWSER_TIMEZONE=Asia/Ho_Chi_Minh

RUN_MODE=collect
